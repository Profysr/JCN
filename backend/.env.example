DEBUG=1
SECRET_KEY=
DATABASE_URL=postgresql://<POSTGRES_USER>:<POSTGRES_PASSWORD>@db:5432/<POSTGRES_DB>

# Database Credentials
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# RabbitMQ Credentials
RABBITMQ_DEFAULT_USER=
RABBITMQ_DEFAULT_PASS=

# RabbitMQ — the single message broker (Celery task queue + Channels WebSocket layer)
RABBITMQ_URL=
# Redis — caching / rate-limiting only (NOT a message broker)
REDIS_URL=
ALLOWED_HOSTS=
CORS_ALLOWED_ORIGINS=

# ── v4.3.0 Integrations ────────────────────────────────────────────────────
# Slack — fill in after creating your Slack App at https://api.slack.com/apps
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=

# Frontend origin used in deep-links sent via integration messages
VITE_FRONTEND_URL=
VITE_BACKEND_URL=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY=
FROM_EMAIL=

# ── Local Deployment ─────────────────────────────────────────────────────────
ACCOUNT_EMAIL_VERIFICATION=none

